# ============================================================
# Neo4j 图数据库配置 (空间记忆核 — GraphStore)
# 用于 UI 状态图、状态转换、快捷路径检索
# 不可用时系统自动降级，不阻塞主流程
# ============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=shopping

# ============================================================
# Phone Agent VLM 模型配置
# ============================================================
# API 端点地址
PHONE_AGENT_BASE_URL=http://localhost:8000/v1

# 模型名称 (支持: autoglm-phone, autoglm-phone-9b, ui-tars, qwen-vl, mai-ui, gui-owl)
PHONE_AGENT_MODEL=autoglm-phone-9b

# API 密钥
PHONE_AGENT_API_KEY=EMPTY

# 单任务最大执行步数
PHONE_AGENT_MAX_STEPS=100

# 单次 VLM 推理最大输出 token 数 (默认 4096)
PHONE_AGENT_MAX_TOKENS=4096

# 设备类型: adb (Android) / hdc (HarmonyOS) / ios
PHONE_AGENT_DEVICE_TYPE=adb

# 提示语言: cn (中文) / en (英文)
PHONE_AGENT_LANG=cn

# ============================================================
# 记忆系统
# ============================================================
# 是否启用个性化记忆系统 (FAISS + Neo4j + UnifiedSessionState)
# 关闭: ENABLE_MEMORY=false
ENABLE_MEMORY=true

# ============================================================
# 离线 VLM 配置 (用于 import_manual_data.py 的布局提取)
# ============================================================
OFFLINE_VLM_BASE_URL=https://api.openai.com/v1
OFFLINE_VLM_MODEL=gpt-4o-mini
OFFLINE_VLM_API_KEY=your_offline_vlm_api_key

# ============================================================
# Embedding 嵌入模型配置 (FAISS 向量化)
# ============================================================
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large
